<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.0.dtd">
<suite name="Qace Smoke Suite" parallel="classes" thread-count="2">
    <test name="Smoke - UI">
        <parameter name="browser" value="chrome"/>
        <groups>
            <run>
                <include name="smoke"/>
            </run>
        </groups>
        <classes>
            <class name="tests.ui.LoginTest"/>
            <class name="tests.ui.ProjectsPageTest"/>
            <class name="tests.ui.ProjectPageTest"/>
            <class name="tests.ui.ProjectSettingsPageTest"/>
            <class name="tests.ui.DefectsPageTest"/>
        </classes>
    </test>

    <test name="Smoke - API">
        <groups>
            <run>
                <include name="api"/>
            </run>
        </groups>
        <classes>
            <class name="tests.api.ProjectAPITest"/>
            <class name="tests.api.TestSuiteAPITest"/>
            <class name="tests.api.TestCaseAPITest"/>
            <class name="tests.api.DefectAPITest"/>
        </classes>
    </test>
</suite>
